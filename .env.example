# Database (Neon PostgreSQL)
# Gunakan connection pooling URL untuk queries biasa
NEON_PRISMA_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?channel_binding=require&connect_timeout=15&sslmode=require"

# Direct connection (non-pooling) — untuk Prisma Migrate
NEON_URL_NON_POOLING="postgresql://user:password@host.region.aws.neon.tech/dbname?channel_binding=require&sslmode=require"

# NextAuth
# Ganti dengan URL produksi Anda
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate dengan: openssl rand -hex 32
NEXTAUTH_SECRET="your-secret-key-here"
